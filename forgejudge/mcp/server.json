{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ahmedEid1/forgejudge",
  "description": "Open eval leaderboard + CI gate for autonomous coding agents (solve, score, trace).",
  "version": "0.1.0",
  "repository": {
    "url": "https://github.com/ahmedEid1/forgejudge",
    "source": "github"
  },
  "websiteUrl": "https://forgejudge.ahmedhobeishy.tech",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "forgejudge",
      "version": "0.1.0",
      "runtimeHint": "uvx",
      "runtimeArguments": [
        { "type": "named", "name": "--from", "value": "forgejudge[mcp]==0.1.0" },
        { "type": "positional", "value": "python" },
        { "type": "positional", "value": "-m" },
        { "type": "positional", "value": "forgejudge.mcp.server" }
      ],
      "transport": { "type": "stdio" }
    }
  ]
}
