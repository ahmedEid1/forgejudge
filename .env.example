# ForgeJudge environment — copy to `.env` and fill in. The real `.env` is gitignored.
#
#   cp .env.example .env
#
# Nothing here is required for the deterministic, offline parts of the project:
# `forgejudge selftest` and `uv run pytest -m "not slow"` need no keys and no
# network. Keys are only needed to actually *call a model* (solve / sweep), emit
# traces, or write to the run store. Every var below is read by this repo — grep
# `os.getenv` / `os.environ` to confirm.

# ─── LLM providers (LiteLLM router · strict-$0 free tiers) ───────────────────
# The router (forgejudge/llm/router.py) hands model ids to LiteLLM, which reads
# the matching provider key from the environment. Groq is the primary loop;
# Gemini is the judge fallback. See forgejudge/llm/models.yaml for the chains.
GROQ_API_KEY=          # primary loop — Llama 3.3 70B / gpt-oss-120b (required to solve)
GEMINI_API_KEY=        # judge fallback — gemini-2.5-flash (public-OSS data only)
GOOGLE_API_KEY=        # alias some SDKs expect for Gemini
MISTRAL_API_KEY=       # optional fallback
OPENROUTER_API_KEY=    # optional; hardest patch step (qwen3-coder:free). $10 → 1000 RPD

# Optional: point the router at a different role→model chain file.
# FORGEJUDGE_MODELS_YAML=./forgejudge/llm/models.yaml

# ─── Observability (OpenTelemetry GenAI → Langfuse Cloud) ────────────────────
# Tracing is a no-op unless BOTH the public and secret key are set
# (forgejudge/obs/tracing.py); leave blank to run without traces.
LANGFUSE_PUBLIC_KEY=   # Langfuse Cloud (curated showcase runs)
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Optional: also export OTLP spans to a local Phoenix collector.
# PHOENIX_OTLP_ENDPOINT=http://localhost:6006/v1/traces

# ─── Run store (Neon / local pgvector) ──────────────────────────────────────
# The store (forgejudge/store/db.py) prefers DATABASE_URL, then falls back to
# FJ_LOCAL_DATABASE_URL. DB-marked tests read ONLY FJ_LOCAL_DATABASE_URL and
# refuse any non-loopback host (they TRUNCATE — never point it at production).
FJ_LOCAL_DATABASE_URL=postgresql://forgejudge:forgejudge@localhost:5433/forgejudge  # disposable local pgvector
DATABASE_URL=          # public leaderboard DB — Neon (Postgres + pgvector)

# ─── Guarded live playground (playground_api/app.py · FastAPI / HF Space) ────
# All optional — sensible defaults are baked in; override to tighten the guard.
RATE_LIMIT_PER_HOUR=5      # per-IP sliding-window cap (default 5)
DAILY_TOKEN_BUDGET=200000  # fail-closed daily token budget; 503 once spent (default 200000)
SOLVE_BUDGET_USD=0.05      # per-solve $ ceiling handed to the solver (default 0.05)
TURNSTILE_SECRET=          # Cloudflare Turnstile secret; CAPTCHA enforced only when set

# ─── Namespace / deploy (CI/release only — not needed for local dev) ─────────
PYPI_TOKEN=
NPM_TOKEN=
CLOUDFLARE_API_TOKEN=  # Pages/Workers + DNS for forgejudge.ahmedhobeishy.tech
HF_TOKEN=              # Hugging Face Space (guarded live playground)
