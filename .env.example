# ForgeJudge environment — copy to .env and fill in. The real .env is gitignored.

# --- LLM providers (LiteLLM router; strict-$0 free tiers) ---
GROQ_API_KEY=          # primary high-volume loop (Llama 3.3 70B / gpt-oss-120b)
GEMINI_API_KEY=        # long-context judge fallback (public-OSS data only)
GOOGLE_API_KEY=        # alias some SDKs expect for Gemini
MISTRAL_API_KEY=       # optional fallback
OPENROUTER_API_KEY=    # optional; hardest patch step (qwen3-coder:free). $10 → 1000 RPD

# --- Observability ---
LANGFUSE_PUBLIC_KEY=   # Langfuse Cloud (curated showcase runs)
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Run store ---
FJ_LOCAL_DATABASE_URL=postgresql://forgejudge:forgejudge@localhost:5433/forgejudge  # local pgvector docker
DATABASE_URL=          # dedicated ForgeJudge Neon (Postgres + pgvector) for the public leaderboard

# --- Namespace / deploy ---
PYPI_TOKEN=
NPM_TOKEN=
CLOUDFLARE_API_TOKEN=  # Pages/Workers + DNS for forgejudge.ahmedhobeishy.tech
HF_TOKEN=              # Hugging Face Space (guarded live playground)
